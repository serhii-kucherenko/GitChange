    "conventional-commits-parser": "7.0.0",
    "drizzle-orm": "0.45.2",
    "es-git": "0.7.0",
    "gray-matter": "4.0.3",
    "minimatch": "10.2.5",
    "piscina": "5.2.0",
    "simple-git": "3.36.0",
    "ulid": "2.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.15.32",
    "drizzle-kit": "0.31.10"
  }
}
