{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitchange.dev/schemas/decision-mining-context.schema.json",
  "title": "GitChangeDecisionMiningContext",
  "description": "Bounded input for host-AI decision mining from intelligence.json and indexed SQLite.",
  "type": "object",
  "properties": {
    "candidates": {
      "maxItems": 30,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "candidateId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "seedEvidence": {
            "minItems": 1,
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "commit"
                    },
                    "sha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    }
                  },
                  "required": [
                    "type",
                    "sha"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "file"
                    },
                    "path": {
                      "type": "string"
                    },
                    "commitSha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "commitSha"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "doc"
                    },
                    "path": {
                      "type": "string"
                    },
                    "commitSha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    },
                    "excerpt": {
                      "type": "string",
                      "maxLength": 500
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "commitSha",
                    "excerpt"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "hunk"
                    },
                    "path": {
                      "type": "string"
                    },
                    "commitSha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    },
                    "startLine": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "endLine": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "commitSha",
                    "startLine",
                    "endLine"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "interview"
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "recordedAt": {
                      "type": "string",
                      "minLength": 1
                    },
                    "excerpt": {
                      "type": "string",
                      "maxLength": 500
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "recordedAt",
                    "excerpt"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          },
          "relatedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sourceSignals": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "candidateId",
          "title",
          "seedEvidence",
          "relatedPaths",
          "sourceSignals"
        ],
        "additionalProperties": false
      }
    },
    "erasSummary": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "eraCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "inflectionCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "eras": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "summary": {
                    "type": "string"
                  },
                  "inflectionTypes": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "tech_pivot",
                        "scope_steering",
                        "process_shift",
                        "team_ownership_change"
                      ]
                    }
                  }
                },
                "required": [
                  "name",
                  "summary",
                  "inflectionTypes"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "eraCount",
            "inflectionCount",
            "eras"
          ],
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "topChurnFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "changeCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "insertions": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "deletions": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "lastTouchedAt": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "path",
          "changeCount",
          "insertions",
          "deletions",
          "lastTouchedAt"
        ],
        "additionalProperties": false
      }
    },
    "docDeltas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "commitSha": {
            "type": "string",
            "minLength": 40,
            "maxLength": 40
          },
          "excerpt": {
            "type": "string",
            "maxLength": 500
          }
        },
        "required": [
          "path",
          "commitSha",
          "excerpt"
        ],
        "additionalProperties": false
      }
    },
    "expertiseTopics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string"
          },
          "suggestedContributors": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "authorId": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                },
                "rationale": {
                  "type": "string"
                },
                "evidence": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "oneOf": [
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "commit"
                          },
                          "sha": {
                            "type": "string",
                            "minLength": 40,
                            "maxLength": 40
                          }
                        },
                        "required": [
                          "type",
                          "sha"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "file"
                          },
                          "path": {
                            "type": "string"
                          },
                          "commitSha": {
                            "type": "string",
                            "minLength": 40,
                            "maxLength": 40
                          }
                        },
                        "required": [
                          "type",
                          "path",
                          "commitSha"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "doc"
                          },
                          "path": {
                            "type": "string"
                          },
                          "commitSha": {
                            "type": "string",
                            "minLength": 40,
                            "maxLength": 40
                          },
                          "excerpt": {
                            "type": "string",
                            "maxLength": 500
                          }
                        },
                        "required": [
                          "type",
                          "path",
                          "commitSha",
                          "excerpt"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "hunk"
                          },
                          "path": {
                            "type": "string"
                          },
                          "commitSha": {
                            "type": "string",
                            "minLength": 40,
                            "maxLength": 40
                          },
                          "startLine": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 9007199254740991
                          },
                          "endLine": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 9007199254740991
                          }
                        },
                        "required": [
                          "type",
                          "path",
                          "commitSha",
                          "startLine",
                          "endLine"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "const": "interview"
                          },
                          "path": {
                            "type": "string",
                            "minLength": 1
                          },
                          "recordedAt": {
                            "type": "string",
                            "minLength": 1
                          },
                          "excerpt": {
                            "type": "string",
                            "maxLength": 500
                          }
                        },
                        "required": [
                          "type",
                          "path",
                          "recordedAt",
                          "excerpt"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  }
                }
              },
              "required": [
                "authorId",
                "name",
                "email",
                "score",
                "rationale",
                "evidence"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "topic",
          "suggestedContributors"
        ],
        "additionalProperties": false
      }
    },
    "manifestWarnings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "additionalProperties": false
      }
    },
    "attributionConfidence": {
      "type": "string",
      "enum": [
        "complete",
        "degraded"
      ]
    }
  },
  "required": [
    "candidates",
    "erasSummary",
    "topChurnFiles",
    "docDeltas",
    "expertiseTopics",
    "manifestWarnings",
    "attributionConfidence"
  ],
  "additionalProperties": false
}
