{
  "name": "@gitchange/plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitChange IDE plugin — slash command skills, agent specs, and host-AI JSON schemas",
  "license": "MIT",
  "files": ["skills", "agents", "schemas"],
  "scripts": {
    "build": "tsx scripts/generate-schemas.ts",
    "test": "pnpm --dir ../.. exec vitest run packages/plugin/scripts/resolve-root.test.ts tests/integration/plugin-schemas.test.ts",
    "lint": "node -e \"console.log('no lint targets in plugin package')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@gitchange/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
