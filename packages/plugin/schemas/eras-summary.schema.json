{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitchange.dev/schemas/eras-summary.schema.json",
  "title": "GitChangeErasSummary",
  "description": "Bounded era highlights for snapshot API and host-AI presentation.",
  "type": "object",
  "properties": {
    "eraCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "inflectionCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "eras": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "inflectionTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "tech_pivot",
                "scope_steering",
                "process_shift",
                "team_ownership_change"
              ]
            }
          }
        },
        "required": [
          "name",
          "summary",
          "inflectionTypes"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "eraCount",
    "inflectionCount",
    "eras"
  ],
  "additionalProperties": false
}
