{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitchange.dev/schemas/snapshot.schema.json",
  "title": "GitChangeSnapshotResponse",
  "description": "GET /api/snapshot response shape for host-AI tool registration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest",
    "stats",
    "intelligence",
    "highlights",
    "erasSummary"
  ],
  "properties": {
    "manifest": {
      "$ref": "#/$defs/manifest"
    },
    "stats": {
      "type": "object",
      "properties": {
        "commitCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "fileChangeCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "authorCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "commitCount",
        "fileChangeCount",
        "authorCount"
      ],
      "additionalProperties": false
    },
    "intelligence": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/intelligence"
        }
      ]
    },
    "highlights": {
      "type": "object",
      "properties": {
        "topChurnFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "changeCount": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "path",
              "changeCount"
            ],
            "additionalProperties": false
          }
        },
        "topExpertiseTopics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "topic": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "required": [
              "topic",
              "label"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "topChurnFiles",
        "topExpertiseTopics"
      ],
      "additionalProperties": false
    },
    "erasSummary": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "https://gitchange.dev/schemas/eras-summary.schema.json"
        }
      ]
    }
  },
  "$defs": {
    "manifest": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string"
        },
        "lastIndexedCommit": {
          "type": "string"
        },
        "indexedAt": {
          "type": "string"
        },
        "repo": {
          "type": "object",
          "properties": {
            "head": {
              "type": "string"
            },
            "branch": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "head",
            "branch"
          ],
          "additionalProperties": false
        },
        "indexCompleteness": {
          "type": "string",
          "enum": [
            "complete",
            "partial"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "shallow_clone",
                  "force_push_detected",
                  "out_of_order_commits"
                ]
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "additionalProperties": false
          }
        },
        "intelligenceComputedAt": {
          "type": "string"
        },
        "intelligenceHeadSha": {
          "type": "string"
        },
        "intelligenceSchemaVersion": {
          "type": "string"
        },
        "semanticComputedAt": {
          "type": "string"
        },
        "semanticHeadSha": {
          "type": "string"
        },
        "semanticSchemaVersion": {
          "type": "string"
        }
      },
      "required": [
        "schemaVersion",
        "lastIndexedCommit",
        "indexedAt",
        "repo",
        "indexCompleteness",
        "warnings"
      ],
      "additionalProperties": false
    },
    "intelligence": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string"
        },
        "computedAt": {
          "type": "string"
        },
        "headSha": {
          "type": "string",
          "minLength": 40,
          "maxLength": 40
        },
        "attributionConfidence": {
          "type": "string",
          "enum": [
            "complete",
            "degraded"
          ]
        },
        "churn": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "changeCount": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "insertions": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "deletions": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "lastTouchedAt": {
                    "type": "integer",
                    "minimum": -9007199254740991,
                    "maximum": 9007199254740991
                  },
                  "evidence": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "commit"
                            },
                            "sha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            }
                          },
                          "required": [
                            "type",
                            "sha"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "file"
                            },
                            "path": {
                              "type": "string"
                            },
                            "commitSha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            }
                          },
                          "required": [
                            "type",
                            "path",
                            "commitSha"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "doc"
                            },
                            "path": {
                              "type": "string"
                            },
                            "commitSha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            },
                            "excerpt": {
                              "type": "string",
                              "maxLength": 500
                            }
                          },
                          "required": [
                            "type",
                            "path",
                            "commitSha",
                            "excerpt"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    }
                  }
                },
                "required": [
                  "path",
                  "changeCount",
                  "insertions",
                  "deletions",
                  "lastTouchedAt",
                  "evidence"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "files"
          ],
          "additionalProperties": false
        },
        "coChange": {
          "type": "object",
          "properties": {
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "pathA": {
                    "type": "string"
                  },
                  "pathB": {
                    "type": "string"
                  },
                  "coOccurrence": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "lastCoChangeAt": {
                    "type": "integer",
                    "minimum": -9007199254740991,
                    "maximum": 9007199254740991
                  },
                  "weight": {
                    "type": "number",
                    "minimum": 0
                  },
                  "relationship": {
                    "type": "string",
                    "const": "co_change"
                  },
                  "disclaimer": {
                    "type": "string",
                    "const": "historical correlation, not import dependency"
                  }
                },
                "required": [
                  "pathA",
                  "pathB",
                  "coOccurrence",
                  "lastCoChangeAt",
                  "weight",
                  "relationship",
                  "disclaimer"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "edges"
          ],
          "additionalProperties": false
        },
        "ownership": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "authors": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "authorId": {
                          "type": "integer",
                          "minimum": -9007199254740991,
                          "maximum": 9007199254740991
                        },
                        "name": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string"
                        },
                        "lineCount": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "percentage": {
                          "type": "number",
                          "minimum": 0
                        }
                      },
                      "required": [
                        "authorId",
                        "name",
                        "email",
                        "lineCount",
                        "percentage"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "evidence": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "commit"
                            },
                            "sha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            }
                          },
                          "required": [
                            "type",
                            "sha"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "file"
                            },
                            "path": {
                              "type": "string"
                            },
                            "commitSha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            }
                          },
                          "required": [
                            "type",
                            "path",
                            "commitSha"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "doc"
                            },
                            "path": {
                              "type": "string"
                            },
                            "commitSha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            },
                            "excerpt": {
                              "type": "string",
                              "maxLength": 500
                            }
                          },
                          "required": [
                            "type",
                            "path",
                            "commitSha",
                            "excerpt"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    }
                  }
                },
                "required": [
                  "path",
                  "authors",
                  "evidence"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "files"
          ],
          "additionalProperties": false
        },
        "eraSignals": {
          "type": "object",
          "properties": {
            "boundaries": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "minimum": -9007199254740991,
                    "maximum": 9007199254740991
                  },
                  "signalType": {
                    "type": "string"
                  },
                  "score": {
                    "type": "number"
                  },
                  "startCommitSha": {
                    "type": "string"
                  },
                  "endCommitSha": {
                    "type": "string"
                  },
                  "startAt": {
                    "type": "integer",
                    "minimum": -9007199254740991,
                    "maximum": 9007199254740991
                  },
                  "endAt": {
                    "type": "integer",
                    "minimum": -9007199254740991,
                    "maximum": 9007199254740991
                  },
                  "evidence": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "commit"
                            },
                            "sha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            }
                          },
                          "required": [
                            "type",
                            "sha"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "file"
                            },
                            "path": {
                              "type": "string"
                            },
                            "commitSha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            }
                          },
                          "required": [
                            "type",
                            "path",
                            "commitSha"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "doc"
                            },
                            "path": {
                              "type": "string"
                            },
                            "commitSha": {
                              "type": "string",
                              "minLength": 40,
                              "maxLength": 40
                            },
                            "excerpt": {
                              "type": "string",
                              "maxLength": 500
                            }
                          },
                          "required": [
                            "type",
                            "path",
                            "commitSha",
                            "excerpt"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    }
                  }
                },
                "required": [
                  "id",
                  "signalType",
                  "score",
                  "startCommitSha",
                  "endCommitSha",
                  "startAt",
                  "endAt",
                  "evidence"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "boundaries"
          ],
          "additionalProperties": false
        },
        "eraOwnership": {
          "type": "object",
          "properties": {
            "eras": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "eraId": {
                    "type": "integer",
                    "minimum": -9007199254740991,
                    "maximum": 9007199254740991
                  },
                  "label": {
                    "type": "string"
                  },
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "authors": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "authorId": {
                                "type": "integer",
                                "minimum": -9007199254740991,
                                "maximum": 9007199254740991
                              },
                              "name": {
                                "type": "string"
                              },
                              "email": {
                                "type": "string"
                              },
                              "touchCount": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 9007199254740991
                              },
                              "percentage": {
                                "type": "number",
                                "minimum": 0
                              }
                            },
                            "required": [
                              "authorId",
                              "name",
                              "email",
                              "touchCount",
                              "percentage"
                            ],
                            "additionalProperties": false
                          }
                        }
                      },
                      "required": [
                        "path",
                        "authors"
                      ],
                      "additionalProperties": false
                    }
                  }
                },
                "required": [
                  "eraId",
                  "label",
                  "files"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "eras"
          ],
          "additionalProperties": false
        },
        "expertise": {
          "type": "object",
          "properties": {
            "topics": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "topic": {
                    "type": "string"
                  },
                  "suggestedContributors": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "authorId": {
                          "type": "integer",
                          "minimum": -9007199254740991,
                          "maximum": 9007199254740991
                        },
                        "name": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string"
                        },
                        "score": {
                          "type": "number"
                        },
                        "rationale": {
                          "type": "string"
                        },
                        "evidence": {
                          "minItems": 1,
                          "type": "array",
                          "items": {
                            "oneOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "const": "commit"
                                  },
                                  "sha": {
                                    "type": "string",
                                    "minLength": 40,
                                    "maxLength": 40
                                  }
                                },
                                "required": [
                                  "type",
                                  "sha"
                                ],
                                "additionalProperties": false
                              },
                              {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "const": "file"
                                  },
                                  "path": {
                                    "type": "string"
                                  },
                                  "commitSha": {
                                    "type": "string",
                                    "minLength": 40,
                                    "maxLength": 40
                                  }
                                },
                                "required": [
                                  "type",
                                  "path",
                                  "commitSha"
                                ],
                                "additionalProperties": false
                              },
                              {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "const": "doc"
                                  },
                                  "path": {
                                    "type": "string"
                                  },
                                  "commitSha": {
                                    "type": "string",
                                    "minLength": 40,
                                    "maxLength": 40
                                  },
                                  "excerpt": {
                                    "type": "string",
                                    "maxLength": 500
                                  }
                                },
                                "required": [
                                  "type",
                                  "path",
                                  "commitSha",
                                  "excerpt"
                                ],
                                "additionalProperties": false
                              }
                            ]
                          }
                        }
                      },
                      "required": [
                        "authorId",
                        "name",
                        "email",
                        "score",
                        "rationale",
                        "evidence"
                      ],
                      "additionalProperties": false
                    }
                  }
                },
                "required": [
                  "topic",
                  "suggestedContributors"
