      },
      "required": [
        "schemaVersion",
        "computedAt",
        "headSha",
        "attributionConfidence",
        "churn",
        "coChange",
        "ownership",
        "eraSignals",
        "eraOwnership",
        "expertise"
      ],
      "additionalProperties": false
    }
  }
}
