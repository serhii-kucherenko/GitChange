{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitchange.dev/schemas/decisions.schema.json",
  "title": "GitChangeDecisionsArtifact",
  "description": "Past decisions and migrations with status, evidence, supersession, and attribution.",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "computedAt": {
      "type": "string"
    },
    "headSha": {
      "type": "string",
      "minLength": 40,
      "maxLength": 40
    },
    "decisions": {
      "maxItems": 40,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^decision:.*"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "accepted",
              "rejected",
              "superseded",
              "in_flight",
              "unknown"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "minItems": 1,
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "commit"
                    },
                    "sha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    },
                    "repoId": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "type",
                    "sha"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "file"
                    },
                    "path": {
                      "type": "string"
                    },
                    "commitSha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    },
                    "repoId": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "commitSha"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "doc"
                    },
                    "path": {
                      "type": "string"
                    },
                    "commitSha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    },
                    "excerpt": {
                      "type": "string",
                      "maxLength": 500
                    },
                    "repoId": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "commitSha",
                    "excerpt"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "hunk"
                    },
                    "path": {
                      "type": "string"
                    },
                    "commitSha": {
                      "type": "string",
                      "minLength": 40,
                      "maxLength": 40
                    },
                    "startLine": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "endLine": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "repoId": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "commitSha",
                    "startLine",
                    "endLine"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "interview"
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "recordedAt": {
                      "type": "string",
                      "minLength": 1
                    },
                    "excerpt": {
                      "type": "string",
                      "maxLength": 500
                    },
                    "repoId": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "type",
                    "path",
                    "recordedAt",
                    "excerpt"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          },
          "reviewStatus": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "rejected"
            ]
          },
          "miningSource": {
            "type": "string",
            "enum": [
              "deterministic",
              "agent",
              "interview",
              "manual"
            ]
          },
          "relatedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "supersededBy": {
            "type": "string",
            "pattern": "^decision:.*"
          },
          "supersedes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^decision:.*"
            }
          },
          "attribution": {
            "type": "object",
            "properties": {
              "authorId": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "email": {
                "type": "string",
                "minLength": 1
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "commit"
                        },
                        "sha": {
                          "type": "string",
                          "minLength": 40,
                          "maxLength": 40
                        },
                        "repoId": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "sha"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "file"
                        },
                        "path": {
                          "type": "string"
                        },
                        "commitSha": {
                          "type": "string",
                          "minLength": 40,
                          "maxLength": 40
                        },
                        "repoId": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "path",
                        "commitSha"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "doc"
                        },
                        "path": {
                          "type": "string"
                        },
                        "commitSha": {
                          "type": "string",
                          "minLength": 40,
                          "maxLength": 40
                        },
                        "excerpt": {
                          "type": "string",
                          "maxLength": 500
                        },
                        "repoId": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "path",
                        "commitSha",
                        "excerpt"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "hunk"
                        },
                        "path": {
                          "type": "string"
                        },
                        "commitSha": {
                          "type": "string",
                          "minLength": 40,
                          "maxLength": 40
                        },
                        "startLine": {
                          "type": "integer",
                          "exclusiveMinimum": 0,
                          "maximum": 9007199254740991
                        },
                        "endLine": {
                          "type": "integer",
                          "exclusiveMinimum": 0,
                          "maximum": 9007199254740991
                        },
                        "repoId": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "path",
                        "commitSha",
                        "startLine",
                        "endLine"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "interview"
                        },
                        "path": {
                          "type": "string",
                          "minLength": 1
                        },
                        "recordedAt": {
                          "type": "string",
                          "minLength": 1
                        },
                        "excerpt": {
                          "type": "string",
                          "maxLength": 500
                        },
                        "repoId": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "path",
                        "recordedAt",
                        "excerpt"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              }
            },
            "required": [
              "authorId",
              "name",
              "email",
              "rationale",
              "evidence"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "title",
          "summary",
          "status",
          "confidence",
          "evidence",
          "reviewStatus",
          "miningSource"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "computedAt",
    "headSha",
    "decisions"
  ],
  "additionalProperties": false
}
